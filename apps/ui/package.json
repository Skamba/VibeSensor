{
  "name": "vibesensor-ui",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "sideEffects": false,
  "scripts": {
    "sync:contracts": "node ../../tools/config/sync_contract_artifacts.mjs",
    "sync:generated-contracts": "node ../../tools/config/sync_shared_contracts_to_ui.mjs",
    "setup:generated-contracts": "node ../../tools/ui/ensure_ui_bootstrap.mjs --ensure-generated-contracts",
    "check:contracts": "node ../../tools/config/sync_shared_contracts_to_ui.mjs --check",
    "lint": "biome lint .",
    "lint:deps": "depcruise --config .dependency-cruiser.cjs src",
    "lint:unused": "knip --config knip.jsonc",
    "lint:fix": "biome lint . --write",
    "format": "biome format . --write",
    "format:check": "biome check . --linter-enabled=false --assist-enabled=false",
    "dev": "vite",
    "dev:mock": "vite --mode msw",
    "dev:open": "vite --open",
    "dev:docker": "sh ./dev-docker.sh",
    "build": "npm run check:contracts && vite build",
    "build:prevalidated-contracts": "vite build",
    "preview": "vite preview",
    "typecheck": "npm run check:contracts && tsc --noEmit",
    "typecheck:tests": "tsc --noEmit -p tsconfig.test.json",
    "pretest:regression": "npm run sync:generated-contracts",
    "test:regression": "npx playwright test --config=playwright.regression.config.ts --project=laptop-light",
    "pretest:smoke": "npm run sync:generated-contracts",
    "test:smoke": "npx playwright test --config=playwright.smoke.config.ts --project=laptop-light",
    "test:smoke:mock": "npx playwright test --config=playwright.smoke.msw.config.ts --project=laptop-light",
    "pretest:unit": "npm run sync:generated-contracts",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:visual": "npx playwright test",
    "test:visual:update": "npx playwright test --update-snapshots",
    "test:visual:audit": "npx playwright test --config=playwright.visual-audit.config.ts",
    "test:visual:audit:update": "npx playwright test --config=playwright.visual-audit.config.ts --update-snapshots",
    "screenshot": "node take-screenshot.mjs",
    "snapshot:update": "node update-snapshots.mjs",
    "analyze": "vite build --mode analyze",
    "wiki:screenshots": "node update-wiki-screenshots.mjs"
  },
  "dependencies": {
    "@preact/signals": "^2.9.0",
    "@tanstack/query-core": "^5.100.9",
    "comlink": "^4.4.2",
    "preact": "^10.29.1",
    "valibot": "^1.4.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.14",
    "@playwright/test": "^1.59.1",
    "@preact/preset-vite": "^2.10.5",
    "dependency-cruiser": "^17.4.0",
    "happy-dom": "^20.9.0",
    "knip": "^6.12.2",
    "linkedom": "^0.18.12",
    "msw": "^2.14.5",
    "openapi-typescript": "^7.13.0",
    "rollup-plugin-visualizer": "^7.0.1",
    "typescript": "^5.9.3",
    "vite": "^8.0.11",
    "vitest": "^4.1.5"
  }
}

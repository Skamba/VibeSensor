{
  "$schema": "https://biomejs.dev/schemas/2.4.13/schema.json",
  "files": {
    "ignoreUnknown": true,
    "includes": [
      "**",
      "!src/generated",
      "!src/contracts",
      "!src/constants.ts",
      "!package-lock.json",
      "!test-results",
      "!tests/test-results",
      "!!dist",
      "!!tests/snapshots"
    ]
  },
  "linter": {
    "enabled": true,
    "includes": [
      "src/**/*.ts",
      "tests/**/*.ts",
      "playwright.config.ts",
      "playwright.smoke.config.ts",
      "playwright.smoke.msw.config.ts",
      "playwright.visual-audit.config.ts",
      "vite.config.ts",
      "vitest.config.ts",
      "take-screenshot.mjs",
      "update-snapshots.mjs"
    ],
    "rules": {
      "recommended": true
    }
  },
  "formatter": {
    "enabled": true,
    "includes": [
      "src/**/*.ts",
      "src/**/*.css",
      "src/i18n/catalogs/*.json",
      "tests/**/*.ts",
      "index.html",
      "playwright.config.ts",
      "playwright.smoke.config.ts",
      "playwright.smoke.msw.config.ts",
      "playwright.visual-audit.config.ts",
      "vite.config.ts",
      "vitest.config.ts",
      "take-screenshot.mjs",
      "update-snapshots.mjs",
      "tsconfig.json",
      "package.json",
      "biome.json"
    ],
    "indentStyle": "space"
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "double",
      "semicolons": "always",
      "trailingCommas": "all"
    }
  }
}

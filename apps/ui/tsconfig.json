{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "allowJs": false,
    "checkJs": false,
    "jsx": "react-jsx",
    "jsxImportSource": "preact",
    "strict": true,
    // UI boundary-safety policy: keep production and test source stricter than
    // the baseline `strict` preset where practical.
    "noFallthroughCasesInSwitch": true,
    "noImplicitOverride": true,
    "noPropertyAccessFromIndexSignature": true,
    "skipLibCheck": true,
    "noEmit": true,
    "types": ["vite/client"],
    "resolveJsonModule": true
  },
  "include": ["src"]
}

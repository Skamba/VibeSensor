    "AlignmentInfoPayload": {
      "properties": {
        "aligned": {
          "title": "Aligned",
          "type": "boolean"
        },
        "clock_synced": {
          "title": "Clock Synced",
          "type": "boolean"
        },
        "overlap_ratio": {
          "title": "Overlap Ratio",
          "type": "number"

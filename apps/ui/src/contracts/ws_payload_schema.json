        "location_code": {
          "title": "Location Code",
          "type": "string"
        },
        "mac_address": {
          "title": "Mac Address",
          "type": "string"
        },
        "name": {
          "title": "Name",
          "type": "string"
        },
        "sample_rate_hz": {
          "title": "Sample Rate Hz",
          "type": "integer"
        }

        "overlap_ratio",
        "aligned",
        "shared_window_s",
        "sensor_count",
        "clock_synced"
      ],
      "title": "AlignmentInfoPayload",
      "type": "object"
    },
    "FrequencyWarningPayload": {
      "properties": {
        "client_ids": {
          "items": {
            "type": "string"
          },

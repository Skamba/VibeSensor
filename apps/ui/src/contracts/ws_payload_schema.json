      "properties": {
        "noise_floor_amp_g": {
          "title": "Noise Floor Amp G",
          "type": "number"
        },
        "peak_amp_g": {
          "title": "Peak Amp G",
          "type": "number"
        },
        "strength_bucket": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "title": "Strength Bucket"

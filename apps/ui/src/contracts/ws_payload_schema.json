        "connected": {
          "title": "Connected",
          "type": "boolean"
        },
        "dropped_frames": {
          "title": "Dropped Frames",
          "type": "integer"
        },
        "firmware_version": {
          "title": "Firmware Version",
          "type": "string"
        },
        "frames_total": {
          "title": "Frames Total",
          "type": "integer"
        },
        "id": {
          "title": "Id",
          "type": "string"
        },
        "last_seen_age_ms": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }

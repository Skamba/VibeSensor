{
  "$defs": {
    "AlignmentInfo": {
      "description": "Multi-sensor clock-alignment quality metrics for a frequency window.",
      "properties": {
        "aligned": {
          "title": "Aligned",
          "type": "boolean"
        },
        "clock_synced": {
          "title": "Clock Synced",
          "type": "boolean"
        },
        "overlap_ratio": {
          "title": "Overlap Ratio",
          "type": "number"
        },
        "sensor_count": {
          "title": "Sensor Count",
          "type": "integer"
        },
        "shared_window_s": {
          "title": "Shared Window S",
          "type": "number"
        }
      },
      "required": [
        "overlap_ratio",
        "aligned",
        "shared_window_s",
        "sensor_count",
        "clock_synced"
      ],
      "title": "AlignmentInfo",
      "type": "object"
    },
    "ClientInfoModel": {
      "additionalProperties": false,
      "description": "Structured client row with explicit defaults for optional construction.",
      "properties": {
        "connected": {
          "default": false,
          "title": "Connected",
          "type": "boolean"
        },
        "control_addr": {
          "anyOf": [
            {
              "maxItems": 2,
              "minItems": 2,
              "prefixItems": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ],
              "type": "array"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Control Addr"
        },
        "data_addr": {
          "anyOf": [
            {
              "maxItems": 2,
              "minItems": 2,
              "prefixItems": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ],
              "type": "array"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Data Addr"
        },
        "dropped_frames": {
          "default": 0,
          "title": "Dropped Frames",
          "type": "integer"
        },
        "duplicates_received": {
          "default": 0,
          "title": "Duplicates Received",
          "type": "integer"
        },
        "firmware_version": {
          "default": "",
          "title": "Firmware Version",
          "type": "string"
        },
        "frame_samples": {
          "default": 0,
          "title": "Frame Samples",
          "type": "integer"
        },
        "frames_total": {
          "default": 0,
          "title": "Frames Total",
          "type": "integer"
        },
        "id": {
          "default": "",
          "title": "Id",
          "type": "string"
        },
        "last_ack_cmd_seq": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Last Ack Cmd Seq"
        },
        "last_ack_status": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Last Ack Status"
        },
        "last_reset_time": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Last Reset Time"
        },
        "last_seen_age_ms": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Last Seen Age Ms"
        },
        "latest_metrics": {
          "additionalProperties": true,
          "title": "Latest Metrics",
          "type": "object"
        },
        "location": {
          "default": "",
          "title": "Location",
          "type": "string"
        },
        "mac_address": {
          "default": "",
          "title": "Mac Address",
          "type": "string"
        },
        "name": {
          "default": "",
          "title": "Name",
          "type": "string"
        },
        "parse_errors": {
          "default": 0,
          "title": "Parse Errors",
          "type": "integer"
        },
        "queue_overflow_drops": {
          "default": 0,
          "title": "Queue Overflow Drops",
          "type": "integer"
        },
        "reset_count": {
          "default": 0,
          "title": "Reset Count",
          "type": "integer"
        },
        "sample_rate_hz": {
          "default": 0,
          "title": "Sample Rate Hz",
          "type": "integer"
        },
        "server_queue_drops": {
          "default": 0,
          "title": "Server Queue Drops",
          "type": "integer"
        },
        "timing_health": {
          "$ref": "#/$defs/TimingHealthPayload"
        }
      },
      "title": "ClientInfoModel",
      "type": "object"
    },
    "FrequencyWarning": {
      "description": "Warning about frequency data quality issues in a spectra payload.",
      "properties": {
        "client_ids": {
          "items": {
            "type": "string"
          },
          "title": "Client Ids",
          "type": "array"
        },
        "code": {
          "title": "Code",
          "type": "string"
        },
        "message": {
          "title": "Message",
          "type": "string"
        }
      },
      "required": [
        "code",
        "message",
        "client_ids"
      ],
      "title": "FrequencyWarning",
      "type": "object"
    },
    "OrderBand": {
      "description": "Frequency band for a specific rotation-order harmonic.",
      "properties": {
        "center_hz": {
          "title": "Center Hz",
          "type": "number"
        },
        "key": {
          "title": "Key",
          "type": "string"
        },
        "tolerance": {
          "title": "Tolerance",
          "type": "number"
        }
      },
      "required": [
        "key",
        "center_hz",
        "tolerance"
      ],
      "title": "OrderBand",
      "type": "object"
    },
    "RotationalSpeedValue": {
      "description": "Current rotational speed estimate with source and confidence metadata.",
      "properties": {
        "mode": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Mode"
        },
        "reason": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Reason"
        },
        "rpm": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Rpm"
        }
      },
      "title": "RotationalSpeedValue",
      "type": "object"
    },
    "RotationalSpeeds": {
      "description": "Current per-system rotational speed estimates (wheel, driveshaft, engine).",
      "properties": {
        "basis_speed_source": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Basis Speed Source"
        },
        "driveshaft": {
          "$ref": "#/$defs/RotationalSpeedValue",
          "default": {
            "mode": null,
            "reason": null,
            "rpm": null
          }
        },
        "engine": {
          "$ref": "#/$defs/RotationalSpeedValue",
          "default": {
            "mode": null,
            "reason": null,
            "rpm": null
          }
        },
        "order_bands": {
          "anyOf": [
            {
              "items": {
                "$ref": "#/$defs/OrderBand"
              },
              "type": "array"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Order Bands"
        },
        "wheel": {
          "$ref": "#/$defs/RotationalSpeedValue",
          "default": {
            "mode": null,
            "reason": null,
            "rpm": null
          }
        }
      },
      "title": "RotationalSpeeds",
      "type": "object"
    },
    "SpectraPayload": {
      "additionalProperties": true,
      "description": "Top-level spectra block included on heavy ticks.",
      "properties": {
        "alignment": {
          "anyOf": [
            {
              "$ref": "#/$defs/AlignmentInfo"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "clients": {
          "additionalProperties": {
            "$ref": "#/$defs/SpectrumSeries"
          },
          "default": {},
          "title": "Clients",
          "type": "object"
        },
        "freq": {
          "default": [],
          "items": {
            "type": "number"
          },
          "title": "Freq",
          "type": "array"
        },
        "warning": {
          "anyOf": [
            {
              "$ref": "#/$defs/FrequencyWarning"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        }
      },
      "title": "SpectraPayload",
      "type": "object"
    },
    "SpectrumSeries": {
      "additionalProperties": true,
      "description": "Per-client spectrum data sent on heavy ticks.",
      "properties": {
        "combined_spectrum_amp_g": {
          "default": [],
          "items": {
            "type": "number"
          },
          "title": "Combined Spectrum Amp G",
          "type": "array"
        },
        "freq": {
          "anyOf": [
            {
              "items": {
                "type": "number"
              },
              "type": "array"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Freq"
        },
        "strength_metrics": {
          "$ref": "#/$defs/StrengthMetricsModel"
        },
        "x": {
          "default": [],
          "items": {
            "type": "number"
          },
          "title": "X",
          "type": "array"
        },
        "y": {
          "default": [],
          "items": {
            "type": "number"
          },
          "title": "Y",
          "type": "array"
        },
        "z": {
          "default": [],
          "items": {
            "type": "number"
          },
          "title": "Z",
          "type": "array"
        }
      },
      "title": "SpectrumSeries",
      "type": "object"
    },
    "StrengthMetricsModel": {
      "additionalProperties": false,
      "description": "Structured vibration-strength metrics with explicit defaults.",
      "properties": {
        "combined_spectrum_amp_g": {
          "items": {
            "type": "number"
          },
          "title": "Combined Spectrum Amp G",
          "type": "array"
        },
        "noise_floor_amp_g": {
          "default": 0.0,
          "title": "Noise Floor Amp G",
          "type": "number"
        },
        "peak_amp_g": {
          "default": 0.0,
          "title": "Peak Amp G",
          "type": "number"
        },
        "strength_bucket": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Strength Bucket"
        },
        "top_peaks": {
          "items": {
            "$ref": "#/$defs/StrengthPeak"
          },
          "title": "Top Peaks",
          "type": "array"
        },
        "vibration_strength_db": {
          "default": 0.0,
          "title": "Vibration Strength Db",
          "type": "number"
        }
      },
      "title": "StrengthMetricsModel",
      "type": "object"
    },
    "StrengthPeak": {
      "additionalProperties": false,
      "properties": {
        "amp": {
          "title": "Amp",
          "type": "number"
        },
        "hz": {
          "title": "Hz",
          "type": "number"
        },
        "strength_bucket": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "title": "Strength Bucket"
        },
        "vibration_strength_db": {
          "title": "Vibration Strength Db",
          "type": "number"
        }
      },
      "required": [
        "hz",
        "amp",
        "vibration_strength_db",
        "strength_bucket"
      ],
      "title": "StrengthPeak",
      "type": "object"
    },
    "TimingHealthPayload": {
      "additionalProperties": false,
      "properties": {
        "drift_us_total": {
          "title": "Drift Us Total",
          "type": "number"
        },
        "jitter_us_ema": {
          "title": "Jitter Us Ema",
          "type": "number"
        },
        "last_t0_us": {
          "title": "Last T0 Us",
          "type": "integer"
        }
      },
      "title": "TimingHealthPayload",
      "type": "object"
    }
  },
  "additionalProperties": true,
  "description": "Root model for every WebSocket message pushed to the UI.",
  "properties": {
    "clients": {
      "default": [],
      "items": {
        "$ref": "#/$defs/ClientInfoModel"
      },
      "title": "Clients",
      "type": "array"
    },
    "rotational_speeds": {
      "anyOf": [
        {
          "$ref": "#/$defs/RotationalSpeeds"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "schema_version": {
      "default": "1",
      "title": "Schema Version",
      "type": "string"
    },
    "selected_client_id": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Selected Client Id"
    },
    "server_time": {
      "title": "Server Time",
      "type": "string"
    },
    "spectra": {
      "anyOf": [
        {
          "$ref": "#/$defs/SpectraPayload"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "speed_mps": {
      "anyOf": [
        {
          "type": "number"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Speed Mps"
    }
  },
  "required": [
    "server_time"
  ],
  "title": "LiveWsPayload",
  "type": "object"
}

    },
    "server_time": {
      "title": "Server Time",
      "type": "string"
    },
    "spectra": {
      "$ref": "#/$defs/SpectraPayload"
    },
    "speed_mps": {
      "anyOf": [
        {
          "type": "number"
        },
        {
          "type": "null"
        }
      ],
      "title": "Speed Mps"
    }
  },
  "title": "LiveWsPayload",
  "type": "object"
}

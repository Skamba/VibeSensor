{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    // Production source is gated first; test fixtures still carry
    // index-signature dot-access debt tracked by the test typecheck baseline.
    "noPropertyAccessFromIndexSignature": false,
    "types": [
      "vite/client",
      "vitest"
    ]
  },
  "include": [
    "tests/test-env.d.ts",
    "tests/**/*.ts"
  ]
}

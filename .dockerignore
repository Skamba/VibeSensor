# Version control
.git
.gitignore

# Python caches
__pycache__
*.pyc
*.pyo
*.egg-info

# Virtual envs
.venv
venv

# Node
apps/ui/node_modules

# Build artifacts
artifacts/
apps/ui/dist
apps/ui/test-results

# Runtime data
apps/server/data/*.csv
apps/server/data/*.jsonl
apps/server/data/*.log
apps/server/data/*.db
apps/server/data/*.db-shm
apps/server/data/*.db-wal
apps/server/data/clients.json
apps/server/wifi-secrets.env

# Test directories (not needed at runtime)
apps/server/tests/
apps/server/tests_e2e/
apps/ui/tests/

# IDE / editor
.vscode
.idea
*.swp
*.swo

# CI / infra not needed at runtime
.github
infra/
firmware/
hardware/
docs/
scripts/ai/
examples/

# Dev/CI tooling not needed at runtime
tools/dev/
tools/tests/
tools/simulator
tools/watch_pr_checks.py

# Misc
.ruff_cache
.pytest_cache
.cache
